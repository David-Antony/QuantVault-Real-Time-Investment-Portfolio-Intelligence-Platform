// Prisma Schema for QuantVault — Real-Time Investment Portfolio Intelligence Platform
// PostgreSQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int               @id @default(autoincrement())
  username          String            @unique @db.VarChar(100)
  email             String            @unique @db.VarChar(255)
  passwordHash      String            @map("password_hash") @db.VarChar(255)
  avatarPreset      String            @default("default") @map("avatar_preset") @db.VarChar(50)
  avatarConfig      Json              @default("{}") @map("avatar_config") @db.JsonB
  refreshToken      String?           @map("refresh_token") @db.Text
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  lastLogin         DateTime?         @map("last_login") @db.Timestamptz()
  twoFactorEnabled  Boolean           @default(false) @map("two_factor_enabled")
  twoFactorSecret   String?           @map("two_factor_secret") @db.VarChar(255)
  portfolio         Portfolio?
  auditLogs         AuditLog[]
  priceAlerts       PriceAlert[]
  watchlistItems    WatchlistItem[]

  @@map("users")
}

model Portfolio {
  id           Int                 @id @default(autoincrement())
  userId       Int                 @unique @map("user_id")
  name         String              @default("My Portfolio") @db.VarChar(200)
  cashBalance  Decimal             @default(100000.00) @map("cash_balance") @db.Decimal(15, 2)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz()
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets       Asset[]
  transactions Transaction[]
  snapshots    PortfolioSnapshot[]
  ledgerEntries LedgerEntry[]

  @@map("portfolios")
}

model Asset {
  id            Int       @id @default(autoincrement())
  portfolioId   Int       @map("portfolio_id")
  name          String    @db.VarChar(100)
  type          String    @db.VarChar(50)
  currentPrice  Decimal   @map("current_price") @db.Decimal(15, 2)
  quantity      Decimal   @db.Decimal(15, 6)
  averageCost   Decimal   @map("average_cost") @db.Decimal(15, 2)
  totalInvested Decimal   @map("total_invested") @db.Decimal(15, 2)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("assets")
}

model Transaction {
  id          Int       @id @default(autoincrement())
  portfolioId Int       @map("portfolio_id")
  assetName   String    @map("asset_name") @db.VarChar(100)
  type        String    @db.VarChar(20)
  amount      Decimal   @db.Decimal(15, 2)
  price       Decimal?  @db.Decimal(15, 2)
  quantity    Decimal?  @db.Decimal(15, 6)
  status      String    @default("completed") @db.VarChar(20)
  date        DateTime  @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  action    String   @db.VarChar(60)
  metadata  Json     @default("{}")
  ip        String?  @db.VarChar(60)
  userAgent String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("audit_logs")
}

// ─── Portfolio Daily Snapshots (real chart history) ───────────────────────────
model PortfolioSnapshot {
  id            Int       @id @default(autoincrement())
  portfolioId   Int       @map("portfolio_id")
  totalValue    Decimal   @map("total_value") @db.Decimal(15, 2)
  cashBalance   Decimal   @map("cash_balance") @db.Decimal(15, 2)
  totalGainLoss Decimal   @map("total_gain_loss") @db.Decimal(15, 2)
  date          DateTime  @db.Date
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, date])
  @@index([portfolioId])
  @@map("portfolio_snapshots")
}

// ─── Price Alerts ─────────────────────────────────────────────────────────────
model PriceAlert {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  assetName   String    @map("asset_name") @db.VarChar(100)
  condition   String    @db.VarChar(10)
  targetPrice Decimal   @map("target_price") @db.Decimal(15, 2)
  isActive    Boolean   @default(true) @map("is_active")
  triggeredAt DateTime? @map("triggered_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("price_alerts")
}

// ─── Watchlist ────────────────────────────────────────────────────────────────
model WatchlistItem {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  symbol      String   @db.VarChar(30)
  name        String   @db.VarChar(100)
  notes       String?  @db.VarChar(255)
  targetPrice Decimal? @map("target_price") @db.Decimal(15, 2)
  addedAt     DateTime @default(now()) @map("added_at") @db.Timestamptz()
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([userId])
  @@map("watchlist_items")
}


// --- Immutable Ledger (Event Sourcing) --------------------------------------
model LedgerEntry {
  id          Int       @id @default(autoincrement())
  portfolioId Int       @map("portfolio_id")
  eventType   String    @map("event_type") @db.VarChar(50) // DEPOSIT, BUY, SELL, WITHDRAW
  payload     Json      @db.JsonB
  timestamp   DateTime  @default(now()) @db.Timestamptz()
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, timestamp])
  @@map("ledger_entries")
}

